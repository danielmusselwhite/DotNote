<Window x:Class="DotNote.View.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:DotNote.View"
        xmlns:uc="clr-namespace:DotNote.View.UserControls"
        xmlns:vm="clr-namespace:DotNote.ViewModel"
        mc:Ignorable="d"
        Title="NotesWindow" Height="450" Width="800">

    <Window.Resources>
        <vm:NotesVM x:Key="NotesVM"/>
    </Window.Resources>
    
    <DockPanel DataContext="{StaticResource NotesVM}">
        <!-- Main Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New Notebook" 
                          Command="{Binding NewNotebookCommand}" />
                <MenuItem Header="New Note" 
                          Command="{Binding NewNoteCommand}"
                          CommandParameter="{Binding SelectedNotebook}"/> <!-- Pass the selected notebook as a parameter -->
                
                <Separator/>
                
                <MenuItem Header="Exit" 
                          Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtStatusMessage"/>
            </StatusBarItem>
        </StatusBar>

        <!-- NoteBooks -->
        <ListView DockPanel.Dock="Left"
                  Background="SkyBlue"
                  Width="140"
                  ItemsSource="{Binding Notebooks}"
                  SelectedValue="{Binding SelectedNotebook, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <uc:DisplayNotebook Notebook="{Binding}">
                            <uc:DisplayNotebook.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Rename" 
                                            Command="{Binding Source={StaticResource NotesVM}, Path=EditNotebookCommand}"/>
                                <MenuItem Header="Delete" 
                                            Command="{Binding Source={StaticResource NotesVM}, Path=DeleteNotebookCommand}"
                                            CommandParameter="{Binding}"/>
                                    <!-- CommandParameter set so we know which Notebook we are updating -->
                                </ContextMenu>
                            </uc:DisplayNotebook.ContextMenu>
                        </uc:DisplayNotebook>
                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding Source={StaticResource NotesVM}, Path=IsNotebookEditVisible}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="LostFocus">
                                    <i:InvokeCommandAction Command="{Binding Source={StaticResource NotesVM}, Path=EndEditNotebookCommand}"
                                                           CommandParameter="{Binding}"/> <!-- CommandParameter set so we know which Notebook we are updating -->
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBox>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Notes -->
        <ListView DockPanel.Dock="Left"
                  Width="140"
                  Background="AliceBlue"
                  ItemsSource="{Binding Notes}"
                  SelectedValue="{Binding SelectedNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <uc:DisplayNote Note="{Binding}"/> <!-- Bind each entire note to each item -->
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Speech" Click="speechButton_Click"></Button>
                <ToggleButton x:Name="boldButton" Click="boldButton_Click">
                    <TextBlock Text="B"
                               FontWeight="Bold"/>
                </ToggleButton>
                <ToggleButton x:Name="italicButton" Click="italicButton_Click">
                    <TextBlock Text="I"
                               FontStyle="Italic"/>
                </ToggleButton>
                <ToggleButton x:Name="underlineButton" Click="underlineButton_Click">
                    <TextBlock Text="U"
                               TextDecorations="Underline"/>
                </ToggleButton>

                <ComboBox x:Name="cmbFontFamility"
                          Width="100"
                          SelectionChanged="cmbFontFamility_SelectionChanged" />

                <ComboBox x:Name="cmbFontSize"
                          Width="50"
                          IsEditable="True"
                          Margin="5,0,0,0"
                          TextBoxBase.TextChanged="cmbFontSize_TextChanged" />

                <Button Content="Save" Click="saveButton_Click"></Button>
                <Button Content="Delete" Click="deleteButton_Click"></Button>
            </ToolBar>
        </ToolBarTray>
        
        <!-- Main Content -->
        <Grid DockPanel.Dock="Right">
            <RichTextBox x:Name="rtbContent"
                         TextChanged="rtbContent_TextChanged"
                         SelectionChanged="rtbContent_SelectionChanged"/>
        </Grid>
    </DockPanel>
</Window>
