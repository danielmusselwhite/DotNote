<Window x:Class="DotNote.View.NotesWindow"
        x:Name="windowNotes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:DotNote.View"
        xmlns:uc="clr-namespace:DotNote.View.UserControls"
        xmlns:vm="clr-namespace:DotNote.ViewModel"
        xmlns:ui="clr-namespace:DotNote.ViewModel.Helpers.UiHelpers"
        mc:Ignorable="d"
        Icon="/favicon.ico"
        Title="Notes" Height="450" Width="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>

        <!-- Column layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"
                    MinWidth="100"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="140"
                    MinWidth="100"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>


        <!-- Main Menu -->
        <Menu Grid.Row="0"
                Grid.ColumnSpan="5">
            <MenuItem Header="File">
                <MenuItem Header="New Notebook" 
                          Command="{Binding NewNotebookCommand}" />
                <MenuItem Header="New Note" 
                          Command="{Binding NewNoteCommand}"
                          CommandParameter="{Binding SelectedNotebookVM.Model}"/> <!-- Pass the selected notebook as a parameter -->
                
                <Separator/>
                
                <MenuItem Header="View Profile"
                          Command="{Binding ViewProfileCommand}"/>
                
                <Separator/>

                <MenuItem Header="Exit" 
                          Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4"
                Grid.ColumnSpan="5">
            <StatusBarItem>
                <TextBlock x:Name="txtStatusMessage"/>
            </StatusBarItem>
        </StatusBar>

        <!-- NoteBooks -->
        <ListView Grid.Row="3"
                Grid.Column="0"
                  Background="SkyBlue"
                  HorizontalAlignment="Stretch"
                  ItemsSource="{Binding NotebookVMs}"
                  SelectedValue="{Binding SelectedNotebookVM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <uc:DisplayNotebook Notebook="{Binding}">
                            <uc:DisplayNotebook.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Rename"
                                        Command="{Binding DataContext.EditNotebookCommand, Source={x:Reference windowNotes}}"
                                        CommandParameter="{Binding}"/>
                                    <MenuItem Header="Delete"
                                              Command="{Binding DataContext.DeleteNotebookCommand, Source={x:Reference windowNotes}}"
                                              CommandParameter="{Binding}"/>
                                    <!-- CommandParameter set so we know which Notebook we are updating -->
                                </ContextMenu>
                            </uc:DisplayNotebook.ContextMenu>
                        </uc:DisplayNotebook>

                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding IsRenaming,
                            Converter={StaticResource BoolToVisibilityConverter}}"
                                 ui:FocusExtension.IsFocused="{Binding IsRenaming}">

                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="LostFocus">
                                    <i:InvokeCommandAction Command="{Binding DataContext.EndEditNotebookCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           CommandParameter="{Binding}"/> <!-- CommandParameter set so we know which Notebook we are updating -->
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBox>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Resizable Splitter Notebook & Notes -->
        <GridSplitter Grid.Row="3"
                      Grid.Column="1"/>

        <!-- Notes -->
        <ListView Grid.Row="3"
                Grid.Column="2"
                  HorizontalAlignment="Stretch"
                  Background="AliceBlue"
                  ItemsSource="{Binding Notes}"
                  SelectedValue="{Binding SelectedNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <uc:DisplayNote Note="{Binding}"/> <!-- Bind each entire note to each item -->
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Resizable Splitter Notes & Content -->
        <GridSplitter Grid.Row="3"
                      Grid.Column="3"/>

        <!-- Title Edit Box -->

        <!-- Main Content -->
        <DockPanel Grid.Row="3"
                   Grid.Column="4">

            <!-- Toolbar -->
            <ToolBarTray DockPanel.Dock="Top">
                <ToolBar>
                    <Button Click="speechButton_Click"
                            FontFamily="Segoe Fluent Icons"
                            Content="&#xE720;"
                            ToolTip="Speech to Text"/>

                    <ToggleButton x:Name="boldButton"
                            Click="boldButton_Click">
                        <TextBlock Text="B"
                                   FontWeight="Bold"/>
                    </ToggleButton>
                    <ToggleButton x:Name="italicButton"
                            Click="italicButton_Click">
                        <TextBlock Text="I"
                                   FontStyle="Italic"/>
                    </ToggleButton>
                    <ToggleButton x:Name="underlineButton"
                            Click="underlineButton_Click">
                        <TextBlock Text="U"
                                   TextDecorations="Underline"/>
                    </ToggleButton>

                    <ComboBox x:Name="cmbFontFamility"
                              ItemsSource="{Binding FontFamilies}"
                              Width="100"
                              SelectionChanged="cmbFontFamility_SelectionChanged"/>

                    <ComboBox x:Name="cmbFontSize"
                              ItemsSource="{Binding FontSizes}"
                              Width="50"
                              IsEditable="True"
                              Margin="5,0,0,0"
                              TextBoxBase.TextChanged="cmbFontSize_TextChanged"/>

                    <Button Click="saveButton_Click"
                            FontFamily="Segoe Fluent Icons"
                            Content="&#xE74E;"
                            ToolTip="Save"/>


                    <Button Click="deleteButton_Click"
                            FontFamily="Segoe Fluent Icons"
                            Content="&#xE74D;"
                            ToolTip="Delete"/>
                </ToolBar>
            </ToolBarTray>

            <TextBox DockPanel.Dock="Top"
                     Text="{Binding SelectedNote.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="16"
                     FontWeight="Bold"
                     LostFocus="TitleEdit_LostFocus"
                     IsEnabled="{Binding IsNoteSelected}"/>

            <RichTextBox x:Name="rtbContent"
                         TextChanged="rtbContent_TextChanged"
                         SelectionChanged="rtbContent_SelectionChanged"
                         IsEnabled="{Binding IsNoteSelected}"/>
        </DockPanel>
    </Grid>
</Window>
