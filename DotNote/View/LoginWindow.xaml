<Window x:Class="DotNote.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:DotNote.ViewModel"
        xmlns:local="clr-namespace:DotNote.View"
        xmlns:uc="clr-namespace:DotNote.View.UserControls"
        mc:Ignorable="d"
        Title="LoginWindow" Height="300" Width="440">

    <Window.Resources>
        <ResourceDictionary>
            <vm:LoginVM x:Key="LoginVM"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="MainGrid"
          DataContext="{StaticResource LoginVM}"
          ClipToBounds="True">

        <uc:LoginForm x:Name="LoginPanel">
            <uc:LoginForm.RenderTransform>
                <TranslateTransform/>
            </uc:LoginForm.RenderTransform>
        </uc:LoginForm>

        <uc:RegisterForm x:Name="RegisterPanel"
                         Visibility="Collapsed"
                         Opacity="0">
            <uc:RegisterForm.RenderTransform>
                <TranslateTransform Y="300"/>
            </uc:RegisterForm.RenderTransform>
        </uc:RegisterForm>


    </Grid>
</Window>
