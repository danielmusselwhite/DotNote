<Window x:Class="DotNote.View.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DotNote.ViewModel.Login"
        xmlns:local="clr-namespace:DotNote.View"
        mc:Ignorable="d"
        Title="Profile"
        Height="420"
        Width="350">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <Grid HorizontalAlignment="Center"
      Margin="0,0,0,20">

                <Ellipse Width="120"
             Height="120"
             Stroke="LightGray"
             StrokeThickness="1">

                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding ProfilePicture}"
                        Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

                <Button Width="32"
            Height="32"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Command="{Binding UpdateProfilePictureCommand}"
            ToolTip="Change profile picture">
                    ✏️
                </Button>

            </Grid>

            <TextBlock Text="Email:"/>
            <TextBox Text="{Binding Email}"
                     IsReadOnly="True"/>

            <TextBlock Margin="0,10,0,0"
                       Text="First Name:"/>
            <TextBox Text="{Binding FirstName,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Margin="0,10,0,0"
                       Text="Last Name:"/>
            <TextBox Text="{Binding LastName,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged}"/>

            <Button Content="Reset Password"
                    Margin="0,20,0,0"
                    Command="{Binding UpdatePasswordCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Save"
                        Margin="0,0,5,0"
                        Command="{Binding SaveProfileCommand}"
                        CommandParameter="{Binding}" />

                <Button Grid.Column="1"
                        Content="Cancel"
                        Margin="5,0,0,0"
                        Click="Cancel_Click"
                        Style="{StaticResource CancelButtonStyle}" />
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Window>